generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  QUOTED
  SUBMITTED
  CONFIRMED
  FAILED
  REFUNDED
}

enum WalletChain {
  EVM
  SOLANA
}

enum PaymentKind {
  MESSAGE
  PHOTO_LIKE
  OTHER
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  MODERATED
}

model User {
  id                 String             @id @default(cuid())
  walletAddress      String
  walletChain        WalletChain        @default(EVM)
  email              String?            @unique
  status             UserStatus         @default(PENDING)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  profile            Profile?
  favorites          Favorite[]         @relation("FavoriteOwner")
  receivedFavorites  Favorite[]         @relation("FavoriteProfile")
  payments           Payment[]          @relation("PaymentBuyer")
  receivedPayments   Payment[]          @relation("PaymentCreator")
  referrals          Referral[]         @relation("AffiliateReferrals")
  sentMessages       Message[]          @relation("MessageSender")
  receivedMessages   Message[]          @relation("MessageRecipient")
  photoLikes         PhotoLike[]

  @@unique([walletChain, walletAddress])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  birthDate   DateTime
  city        String?
  country     String
  region      String
  headline    String
  bio         String
  isPublished Boolean  @default(false)
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       Media[]
  messagesSent     BigInt   @default(0)
  messagesReceived BigInt   @default(0)
  ratingPoints     BigInt   @default(0)
  baseMessagePrice Decimal  @default(0.300000) @db.Decimal(36, 6)
}

model Media {
  id         String   @id @default(cuid())
  profileId  String
  storageKey String   @unique
  mimeType   String
  isApproved Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  paidLikes  PhotoLike[]

  @@index([profileId, sortOrder])
}

model Favorite {
  ownerId   String
  profileId String
  createdAt DateTime @default(now())
  owner     User     @relation("FavoriteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  profile   User     @relation("FavoriteProfile", fields: [profileId], references: [id], onDelete: Cascade)

  @@id([ownerId, profileId])
}

model Payment {
  id                String        @id @default(cuid())
  buyerId           String
  creatorId         String?
  kind              PaymentKind  @default(OTHER)
  network           String
  chainId           Int?
  tokenAddress      String
  grossAmount       Decimal       @db.Decimal(36, 6)
  creatorAmount     Decimal       @db.Decimal(36, 6)
  platformAmount    Decimal       @db.Decimal(36, 6)
  affiliateAmount   Decimal       @db.Decimal(36, 6)
  transactionHash   String?       @unique
  quoteNonce        String        @unique
  status            PaymentStatus @default(QUOTED)
  confirmedAt       DateTime?
  createdAt         DateTime      @default(now())
  buyer             User          @relation("PaymentBuyer", fields: [buyerId], references: [id])
  creator           User?         @relation("PaymentCreator", fields: [creatorId], references: [id])
  couponRedemption  CouponRedemption?
  referral          Referral?
  message           Message?
  photoLike         PhotoLike?
}

model Message {
  id                String        @id @default(cuid())
  senderId          String
  recipientId       String
  ciphertext        String
  priceUsdc         Decimal       @db.Decimal(36, 6)
  creatorPointsWhenSent BigInt
  status            MessageStatus @default(SENT)
  paymentId         String?       @unique
  createdAt         DateTime      @default(now())
  readAt            DateTime?
  sender            User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient         User          @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  payment           Payment?      @relation(fields: [paymentId], references: [id])

  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
}

model PhotoLike {
  id             String   @id @default(cuid())
  userId         String
  mediaId        String
  paymentId      String   @unique
  grossAmount    Decimal  @default(0.110000) @db.Decimal(36, 6)
  creatorAmount  Decimal  @default(0.100000) @db.Decimal(36, 6)
  platformAmount Decimal  @default(0.010000) @db.Decimal(36, 6)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media          Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  payment        Payment  @relation(fields: [paymentId], references: [id])

  @@unique([userId, mediaId])
  @@index([mediaId, createdAt])
}

model Coupon {
  id          String             @id @default(cuid())
  code        String             @unique
  percentOff  Int?
  amountOff   Decimal?           @db.Decimal(36, 6)
  active      Boolean            @default(true)
  expiresAt   DateTime?
  redemptions CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  paymentId String   @unique
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  payment   Payment  @relation(fields: [paymentId], references: [id])
}

model Referral {
  id          String   @id @default(cuid())
  affiliateId String
  paymentId   String   @unique
  code        String
  amount      Decimal  @db.Decimal(36, 6)
  createdAt   DateTime @default(now())
  affiliate   User     @relation("AffiliateReferrals", fields: [affiliateId], references: [id])
  payment     Payment  @relation(fields: [paymentId], references: [id])
}

model ModerationCase {
  id          String   @id @default(cuid())
  subjectId   String
  reporterId  String?
  reason      String
  details     String?
  status      String   @default("OPEN")
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  subjectId  String?
  metadata   Json?
  createdAt  DateTime @default(now())
}
