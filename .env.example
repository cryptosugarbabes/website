# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-secret
MESSAGE_ENCRYPTION_SECRET=replace-with-a-different-long-random-secret

# Public treasury destinations. Never put a seed phrase or private key here.
NEXT_PUBLIC_BASE_TREASURY_ADDRESS=0x6E0178828F5C2EEEaaE8E9cdea05D62067D54883
NEXT_PUBLIC_SOLANA_TREASURY_ADDRESS=EjkzchC98rxfQzHgmXD5cCbBQmhp1csqbPHkpXEA9shL

# Base payments remain disabled unless this independently reviewed splitter is configured.
BASE_SPLITTER_ADDRESS=

# Use dedicated production RPC providers rather than public shared endpoints.
BASE_RPC_URL=
SOLANA_RPC_URL=

DATABASE_URL=postgresql://velora:velora@localhost:5432/velora

# Existing-Droplet storage (no Spaces account required).
UPLOAD_ROOT=./data/uploads
APP_ORIGIN=http://localhost:3000
ADMIN_PASSWORD=change-this-before-deploy
# Comma-separated email accounts allowed into the named administrator console.
ADMIN_EMAILS=email@cryptosugarbabes.com
# Dedicated recipient for every website-chat notification.
ADMIN_MESSAGE_ALERT_EMAILS=email@cryptosugarbabes.com

# Passwordless email sign-in (Hostinger Email defaults shown).
EMAIL_SMTP_HOST=smtp.hostinger.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=email@cryptosugarbabes.com
EMAIL_SMTP_PASSWORD=replace-with-the-mailbox-password
EMAIL_FROM="Crypto Sugar Babes <email@cryptosugarbabes.com>"

# Optional offsite backup destination, for example s3://bucket/cryptosugarbabes.
# The server also needs a configured AWS-compatible CLI and storage credentials.
BACKUP_S3_URI=
BACKUP_S3_ENDPOINT=
BACKUP_ENCRYPTION_KEY=

# Optional Slack/Discord-compatible monitoring webhook.
MONITOR_WEBHOOK_URL=

# Optional two-way website-chat bridge. Choose forwarded accounts using the
# Alerts on/off controls in the administrator Notifications page.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_PASSWORD=
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Firebase Admin service-account JSON on one line. This stays on the server and
# is separate from the Android app's non-secret google-services.json file.
FCM_SERVICE_ACCOUNT_JSON=

# Public production APK metadata shown at /android after release signing.
ANDROID_APK_URL=
ANDROID_APP_VERSION=
ANDROID_APK_SHA256=
